# ═══════════════════════════════════════════
# Baby Monitor MVP — Environment variables
# Copy to .env: cp .env.example .env
# ═══════════════════════════════════════════

# Server
PORT=3003
CORS_ORIGIN=*

# Signaling URL — auto-detected by ./start script
# Only set manually if not using ./start
# SIGNALING_URL=http://192.168.x.x:3003

# Baby Station URL — auto-detected by ./start script
# BABY_STATION_URL=http://192.168.x.x:5175

# TURN server (optional — only needed if devices are on different networks)
# Free STUN servers are included by default
# TURN_URL=turn:relay.metered.ca:443?transport=tcp
# TURN_USER=
# TURN_PASS=
